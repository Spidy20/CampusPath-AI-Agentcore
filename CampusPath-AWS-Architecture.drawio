        <!-- Legend -->
        <mxCell id="legend" value="Resume PDF flow:  1. FastAPI uploads PDF to S3  →  2. Invokes Lambda  →  3. Lambda reads PDF &amp; extracts text (pypdf)  →  4. FastAPI deletes temp object and returns editable text to the browser, which then calls /api/resume-review (Bedrock)." style="text;html=1;strokeColor=#7D8998;fillColor=#F8FAF9;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#232F3E;spacing=8;" vertex="1" parent="1">
