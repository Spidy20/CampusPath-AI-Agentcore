# Local Python environments (recreate with pip / uv after clone)
campuspath-venv/
.venv/
venv/
ENV/
env/

# Secrets — never commit credentials or local env files
.env
.env.*
!.env.example
**/.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node / CDK build artifacts (run npm install in agentcore/cdk after clone)
node_modules/
**/cdk/cdk.out/
**/cdk/.cdk.staging/
cdk.out/
.cdk.staging/
dist/

